# Copy to .env and populate with your project's credentials
# Vite requires client-side vars to start with VITE_
VITE_SUPABASE_URL="https://xyzcompany.supabase.co"
VITE_SUPABASE_ANON_KEY="public-anon-key"
# Service role key (keep secret; used for migrations/seeds on server side)
SUPABASE_SERVICE_ROLE_KEY="service-role-key"
# Optional: Stripe public key
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."
